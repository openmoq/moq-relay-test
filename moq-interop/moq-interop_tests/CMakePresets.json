{
  "version": 2,
  "cmakeMinimumRequired": {"major": 3, "minor": 20, "patch": 0},
  "configurePresets": [
    {
      "name": "moxygen",
      "displayName": "Moxygen (full build, Ninja, RelWithDebInfo)",
      "description": "Builds with moxygen_adapter and all subscriber tests. Requires moxygen built via scripts/setup-deps.sh.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "WITH_MOXYGEN_ADAPTER": "ON"
      }
    },
    {
      "name": "moxygen-san",
      "displayName": "Moxygen + ASAN (Debug)",
      "description": "Full build with AddressSanitizer.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build_address",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "WITH_MOXYGEN_ADAPTER": "ON",
        "SANITIZE": "address"
      }
    },
    {
      "name": "core",
      "displayName": "Core only (no moxygen_adapter)",
      "description": "Builds base/, publisher_tests/ and two clean subscriber_tests without moxygen. Still requires folly from getdeps.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build_core",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "WITH_MOXYGEN_ADAPTER": "OFF"
      }
    }
  ],
  "buildPresets": [
    {"name": "moxygen",     "configurePreset": "moxygen"},
    {"name": "moxygen-san", "configurePreset": "moxygen-san"},
    {"name": "core",        "configurePreset": "core"}
  ]
}
