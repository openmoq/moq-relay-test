{
  "name": "multi-sub-bench",
  "displayName": "Multi-Subscriber",
  "description": "Spawns N simultaneous subscribers against a relay and measures aggregate throughput, per-subscriber latency, and success rate.",
  "category": "performance",
  "docker": {
    "image": "ghcr.io/gmarzot/aiomoqt:0.8.2",
    "entrypoint": ["python"],
    "command": ["/app/aiomoqt/examples/multi_sub_bench.py"],
    "network": "host"
  },
  "parameters": [
    {
      "id": "relay_url",
      "label": "Relay URL",
      "type": "url",
      "required": true,
      "default": "",
      "placeholder": "https://relay.example.com/moq-relay",
      "description": "MoQT relay endpoint URL"
    },
    {
      "id": "draft",
      "label": "Draft Version",
      "type": "select",
      "options": [
        { "value": "16", "label": "Draft 16" },
        { "value": "14", "label": "Draft 14" }
      ],
      "default": "16"
    },
    {
      "id": "subscribers",
      "label": "Number of Subscribers",
      "type": "number",
      "default": 100,
      "min": 1,
      "max": 1000,
      "description": "Number of simultaneous subscriber connections"
    },
    {
      "id": "video",
      "label": "Video Quality",
      "type": "select",
      "options": [
        { "value": "40p",   "label": "40p" },
        { "value": "270p",  "label": "270p" },
        { "value": "360p",  "label": "360p" },
        { "value": "480p",  "label": "480p" },
        { "value": "720p",  "label": "720p (default)" },
        { "value": "1080p", "label": "1080p" },
        { "value": "1440p", "label": "1440p" },
        { "value": "4k",    "label": "4K" }
      ],
      "default": "720p"
    },
    {
      "id": "duration",
      "label": "Duration (seconds)",
      "type": "number",
      "default": 60,
      "min": 10,
      "max": 600,
      "description": "Test duration in seconds"
    }
  ],
  "buildCommand": "{relay_url} --draft {draft} -n {subscribers} --video {video} -t {duration}",
  "renderer": "renderer.js",
  "selfTest": {
    "enabled": false
  }
}
