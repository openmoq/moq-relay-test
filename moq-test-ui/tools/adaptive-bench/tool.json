{
  "name": "adaptive-bench",
  "displayName": "Adaptive Bitrate",
  "description": "Adjusts publish bitrate to maintain target latency against a relay. Measures bandwidth, latency, loss, and adaptive algorithm behavior.",
  "category": "performance",
  "docker": {
    "image": "ghcr.io/gmarzot/aiomoqt:0.8.2",
    "entrypoint": ["python"],
    "command": ["/app/aiomoqt/examples/adaptive_bench.py"],
    "network": "host"
  },
  "parameters": [
    {
      "id": "relay_url",
      "label": "Relay URL",
      "type": "url",
      "required": true,
      "default": "",
      "placeholder": "https://relay.example.com/moq-relay",
      "description": "MoQT relay endpoint URL"
    },
    {
      "id": "draft",
      "label": "Draft Version",
      "type": "select",
      "options": [
        { "value": "16", "label": "Draft 16" },
        { "value": "14", "label": "Draft 14" }
      ],
      "default": "16"
    },
    {
      "id": "sub_mbps",
      "label": "Target Bandwidth (Mbps)",
      "type": "number",
      "default": 10,
      "min": 1,
      "max": 100,
      "description": "Starting target bandwidth for adaptive algorithm"
    },
    {
      "id": "interval",
      "label": "Reporting Interval (seconds)",
      "type": "number",
      "default": 5,
      "min": 1,
      "max": 60
    },
    {
      "id": "duration",
      "label": "Duration (seconds)",
      "type": "number",
      "default": 60,
      "min": 10,
      "max": 600,
      "description": "Test duration in seconds (0 = unlimited)"
    }
  ],
  "runTimeoutParam": "duration",
  "buildCommand": "-r {relay_url} --draft {draft} --sub-mbps {sub_mbps} --interval {interval}",
  "filters": [
    { "id": "debug", "label": "Hide debug output", "pattern": "^\\[DEBUG\\]|^D\\d{4}", "default": true },
    { "id": "connection", "label": "Hide connection logs", "pattern": "\\[connect\\]|Creating.*connection|QUIC.*handshake", "default": false }
  ],
  "renderer": "renderer.js",
  "selfTest": {
    "enabled": true,
    "order": 4,
    "defaults": {
      "sub_mbps": 10,
      "draft": "16",
      "interval": 5,
      "duration": 60
    }
  }
}
